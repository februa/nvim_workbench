#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
while [[ -L "${script_path}" ]]; do
  script_dir="$(cd "$(dirname "${script_path}")" && pwd)"
  link_target="$(readlink "${script_path}")"
  if [[ "${link_target}" = /* ]]; then
    script_path="${link_target}"
  else
    script_path="${script_dir}/${link_target}"
  fi
done
workbench_dir="$(cd "$(dirname "${script_path}")/.." && pwd)"
project_dir="$(pwd -P)"

container_args=()
for arg in "$@"; do
  if [[ "${arg}" = /* ]]; then
    case "${arg}" in
      "${project_dir}")
        arg="/workspace"
        ;;
      "${project_dir}"/*)
        arg="/workspace/${arg#"${project_dir}"/}"
        ;;
      *)
        echo "Absolute path is outside the mounted working directory: ${arg}" >&2
        echo "Change directory to a parent of the file, then run nvim again." >&2
        exit 1
        ;;
    esac
  fi
  container_args+=("${arg}")
done

if (( ${#container_args[@]} == 0 )); then
  exec "${workbench_dir}/scripts/run.sh" "${project_dir}"
else
  exec "${workbench_dir}/scripts/run.sh" "${project_dir}" "${container_args[@]}"
fi
