#!/usr/bin/env bash
set -euo pipefail

output="${1:-/dev/stdout}"
plugin_root="/home/nvim/.local/share/nvim/dpp/repos/github.com"

{
  echo "nvim-workbench frozen manifest"
  echo
  echo "Tools"
  nvim --version | head -n 3
  deno --version | head -n 1
  if command -v tree-sitter >/dev/null 2>&1; then
    tree-sitter --version
  else
    echo "tree-sitter $(cat /opt/workbench/tree-sitter-version.txt) (build-only)"
  fi
  lua-language-server --version
  pyright --version
  ruff --version
  stylua --version
  clangd --version | head -n 1
  node --version
  rg --version | head -n 1
  fd --version
  shellcheck --version | awk '/^version:/ { print "ShellCheck " $2 }'
  echo
  echo "Plugins"
  if [[ -f /opt/workbench/plugin-manifest.txt ]]; then
    cat /opt/workbench/plugin-manifest.txt
  else
    find "${plugin_root}" -mindepth 2 -maxdepth 2 -type d -print0 \
      | while IFS= read -r -d '' plugin; do
          printf '%s\t%s\n' "${plugin#${plugin_root}/}" "$(git -C "${plugin}" rev-parse HEAD)"
        done \
      | sort
  fi
  echo
  echo "Debian packages"
  dpkg-query --show --showformat='${binary:Package}\t${Version}\n' | sort
} > "${output}"
